internal static class __QueryLensOfflineCapture__
{
    private sealed record __QueryLensRelationalFacadeMethods__(MethodInfo? SetDbConnection, MethodInfo? GetDbConnection);

    private static readonly System.Collections.Concurrent.ConcurrentDictionary<string, __QueryLensRelationalFacadeMethods__>
        SRelationalFacadeMethodsCache = new(StringComparer.Ordinal);

    private static readonly System.Collections.Concurrent.ConcurrentDictionary<string, Func<DbParameter>?>
        SProviderParameterFactoryCache = new(StringComparer.Ordinal);

    public static bool TryInstall(object dbContext, out string? skipReason)
    {
        skipReason = null;

        try
        {
            var databaseProp = dbContext.GetType().GetProperty("Database", BindingFlags.Public | BindingFlags.Instance);
            if (databaseProp is null)
            {
                skipReason = "Could not locate 'Database' property on DbContext.";
                return false;
            }

            var database = databaseProp.GetValue(dbContext);
            if (database is null)
            {
                skipReason = "DbContext.Database returned null.";
                return false;
            }

            var alc = System.Runtime.Loader.AssemblyLoadContext.GetLoadContext(dbContext.GetType().Assembly);
            var assemblies = alc is null ? Enumerable.Empty<Assembly>() : alc.Assemblies;

            // Build a provider-specific DbParameter factory so type mappings that hard-cast
            // DbParameter to their provider type (e.g. NpgsqlParameter) don't throw.
            var paramFactory = ResolveProviderParameterFactory(assemblies);

            var relAsm = assemblies.FirstOrDefault(a => a.GetName().Name == "Microsoft.EntityFrameworkCore.Relational");
            if (relAsm is null)
            {
                skipReason = "Microsoft.EntityFrameworkCore.Relational not loaded - provider may not be relational.";
                return false;
            }

            var methods = ResolveRelationalFacadeMethods(relAsm);
            if (methods.SetDbConnection is null)
            {
                skipReason = "SetDbConnection not found on RelationalDatabaseFacadeExtensions.";
                return false;
            }

            // If this DbContext came from the pool it may already have our offline connection
            // installed from a previous run.  Re-calling SetDbConnection when EF Core's
            // internal open-count is > 0 throws "The instance of DbConnection is currently in
            // use."  The SQL capture scope is AsyncLocal (per-run), so the existing offline
            // connection will route commands to the current run's scope — no reinstall needed.
            //
            // IMPORTANT: check type IDENTITY, not just name.  Each Roslyn eval assembly lives
            // in its own ALC with its own __QueryLensOfflineDbConnection__ type and its own
            // __QueryLensSqlCaptureScope__.AsyncLocal instance.  A name-only match on a
            // connection installed by a different ALC would route Record() calls to that ALC's
            // (now-null) scope and silently drop all captured SQL.  Only skip reinstall when
            // the installed connection is THIS assembly's type — same ALC, same capture scope.
            var getConnMethod = methods.GetDbConnection;
            if (getConnMethod is not null)
            {
                var existingConn = getConnMethod.Invoke(null, new[] { database });
                if (existingConn?.GetType() == typeof(__QueryLensOfflineDbConnection__))
                    return true;
                // Different ALC's offline connection — its _openedCount may be stuck > 0 if
                // a previous run threw before CloseAsync.  Reset it so SetDbConnection succeeds.
                if (existingConn?.GetType().Name == "__QueryLensOfflineDbConnection__")
                    TryResetRelationalOpenCount(database, relAsm);
            }

            var offlineConn = new __QueryLensOfflineDbConnection__(paramFactory);
            var paramCount = methods.SetDbConnection.GetParameters().Length;
            var args = paramCount >= 3
                ? new object?[] { database, offlineConn, true }
                : new object?[] { database, offlineConn };
            methods.SetDbConnection.Invoke(null, args);
            return true;
        }
        catch (Exception ex)
        {
            skipReason = $"SetDbConnection failed: {(ex is TargetInvocationException tie ? tie.InnerException?.Message : ex.Message)}";
            return false;
        }
    }

    private static __QueryLensRelationalFacadeMethods__ ResolveRelationalFacadeMethods(Assembly relAsm)
    {
        var relAsmId = relAsm.FullName ?? relAsm.GetName().Name ?? string.Empty;

        return SRelationalFacadeMethodsCache.GetOrAdd(relAsmId, _ =>
        {
            var extType = relAsm.GetType("Microsoft.EntityFrameworkCore.RelationalDatabaseFacadeExtensions");
            if (extType is null)
            {
                return new __QueryLensRelationalFacadeMethods__(null, null);
            }

            var setMethod = extType.GetMethods(BindingFlags.Public | BindingFlags.Static)
                .Where(m => m.Name == "SetDbConnection")
                .OrderByDescending(m => m.GetParameters().Length)
                .FirstOrDefault();

            var getConnMethod = extType.GetMethods(BindingFlags.Public | BindingFlags.Static)
                .FirstOrDefault(m => m.Name == "GetDbConnection" && m.GetParameters().Length == 1);

            return new __QueryLensRelationalFacadeMethods__(setMethod, getConnMethod);
        });
    }

    private static Func<DbParameter>? ResolveProviderParameterFactory(IEnumerable<Assembly> assemblies)
    {
        var npgsqlAsm = assemblies.FirstOrDefault(a => a.GetName().Name == "Npgsql");
        if (npgsqlAsm is null)
            return null;

        var key = npgsqlAsm.FullName ?? npgsqlAsm.GetName().Name ?? "Npgsql";
        return SProviderParameterFactoryCache.GetOrAdd(key, _ =>
        {
            var npgsqlParamType = npgsqlAsm.GetType("Npgsql.NpgsqlParameter");
            if (npgsqlParamType is null)
                return null;

            return () => (DbParameter)Activator.CreateInstance(npgsqlParamType)!;
        });
    }

    // Resets EF Core RelationalConnection._openedCount to 0 so that SetDbConnection can
    // replace a stale offline connection left open by a previous run that threw.
    private static void TryResetRelationalOpenCount(object database, Assembly relAsm)
    {
        try
        {
            // DatabaseFacade implements IInfrastructure<IServiceProvider> — use it to get
            // the IRelationalConnection service without hard-referencing EF Core types.
            var infraType = database.GetType().GetInterfaces()
                .FirstOrDefault(i => i.IsGenericType && i.Name.StartsWith("IInfrastructure"));
            if (infraType is null) return;
            var instanceProp = infraType.GetProperty("Instance");
            if (instanceProp is null) return;
            var sp = instanceProp.GetValue(database) as IServiceProvider;
            if (sp is null) return;

            var relConnType = relAsm.GetType("Microsoft.EntityFrameworkCore.Storage.IRelationalConnection");
            if (relConnType is null) return;
            var relConn = sp.GetService(relConnType);
            if (relConn is null) return;

            var type = relConn.GetType();
            while (type is not null)
            {
                var field = type.GetField("_openedCount", BindingFlags.NonPublic | BindingFlags.Instance);
                if (field is not null) { field.SetValue(relConn, 0); return; }
                type = type.BaseType;
            }
        }
        catch { }
    }
}
