<idea-plugin>
    <id>dev.efquerylens.rider</id>
    <name>EF QueryLens</name>
    <vendor email="opensource@efquerylens.dev">EF QueryLens Contributors</vendor>
    <description>EF QueryLens integration for Rider.</description>

    <depends>com.intellij.modules.rider</depends>

    <extensions defaultExtensionNs="com.intellij">
        <platform.lsp.serverSupportProvider implementation="efquerylens.EFQueryLensLspServerSupportProvider" />
        <postStartupActivity implementation="efquerylens.EFQueryLensProjectStartupWarmupActivity" />
        <browserUrlOpener implementation="efquerylens.EFQueryLensUrlOpener" />
        <toolWindow
                id="EF QueryLens"
                anchor="bottom"
                icon="AllIcons.Toolwindows.ToolWindowMessages"
                factoryClass="efquerylens.EFQueryLensLogToolWindowFactory"
                secondary="true"
                canCloseContents="false" />
    </extensions>
</idea-plugin>
