<idea-plugin>
    <id>dev.efquerylens</id>
    <name>EF QueryLens</name>
    <vendor email="nemina47@users.noreply.github.com" url="https://github.com/querylenshq/ef-querylens">nemina47</vendor>
    <description>EF QueryLens translates EF Core LINQ into SQL directly in JetBrains Rider and provides quick previews, logs, and copy actions.</description>

    <depends>com.intellij.modules.rider</depends>

    <extensions defaultExtensionNs="com.intellij">
        <platform.lsp.serverSupportProvider implementation="efquerylens.EFQueryLensLspServerSupportProvider" />
        <toolWindow id="EF QueryLens" factoryClass="efquerylens.EFQueryLensLogToolWindowFactory" anchor="bottom" />
        <notificationGroup id="EF QueryLens" displayType="BALLOON" isLogByDefault="false" />
        <intentionAction>
            <className>efquerylens.EFQueryLensCopySqlIntentionAction</className>
            <category>EF QueryLens</category>
        </intentionAction>
        <intentionAction>
            <className>efquerylens.EFQueryLensOpenSqlIntentionAction</className>
            <category>EF QueryLens</category>
        </intentionAction>
        <intentionAction>
            <className>efquerylens.EFQueryLensReanalyzeIntentionAction</className>
            <category>EF QueryLens</category>
        </intentionAction>
    </extensions>

    <extensions defaultExtensionNs="org.jetbrains">
        <urlOpener implementation="efquerylens.EFQueryLensUrlOpener" order="first" />
    </extensions>


    <actions>
        <action id="efquerylens.ShowToolWindow"
                class="efquerylens.EFQueryLensShowToolWindowAction"
                text="Show EF QueryLens"
                description="Open the EF QueryLens log tool window">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
