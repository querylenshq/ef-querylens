{
  "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
  "tasks": [
    {
      "name": "commit-message-linter",
      "command": "dotnet",
      "args": [
        "husky",
        "exec",
        ".husky/csx/commit-lint.csx",
        "--args",
        "${args}"
      ]
    },
    {
      "name": "branch-name-linter",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "husky",
        "exec",
        ".husky/csx/branch-lint.csx"
      ]
    },
    {
      "name": "conflicts-commit-validate",
      "group": "pre-commit",
      "command": "dotnet",
      "args": [
        "husky",
        "exec",
        ".husky/csx/conflicts-commit-validate.csx",
        "--args",
        "${args}"
      ]
    },
    {
      "name": "branch-name-linter-push",
      "group": "pre-push",
      "command": "dotnet",
      "args": [
        "husky",
        "exec",
        ".husky/csx/branch-lint.csx"
      ]
    },
    {
      "name": "dev-release-version-check",
      "group": "pre-push",
      "command": "dotnet",
      "args": [
        "husky",
        "exec",
        ".husky/csx/dev-relase-lint.csx"
      ]
    },
    {
      "name": "prod-release-validate",
      "command": "dotnet",
      "args": [
        "script",
        ".husky/csx/prod-rel-validate.csx"
      ],
      "pathMode": "absolute"
    },
    {
      "name": "prod-release-prepare",
      "command": "dotnet",
      "args": [
        "script",
        ".husky/csx/prep-prod-rel.csx"
      ],
      "pathMode": "absolute"
    },
    {
      "name": "format-csharp",
      "group": "pre-commit",
      "command": "dotnet",
      "args": ["csharpier", "${staged}"],
      "include": ["**/*.cs"]
    },
    {
      "name": "build-warnings-check",
      "command": "dotnet",
      "group": "pre-push",
      "args": ["build", "/warnaserror"],
      "include": ["**/*.cs", "**/*.csproj"]
    }
  ]
}
