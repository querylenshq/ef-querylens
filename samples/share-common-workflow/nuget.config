<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="NuGet.org" value="https://api.nuget.org/v3/index.json" />
    <add key="gitlab" value="https://git.tsp.dev/api/v4/groups/933/-/packages/nuget/index.json" disableTLSCertificateValidation="true" />
    <add key="local" value="../LocalNugetStore" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="NuGet.org">
      <!-- Default to NuGet.org for all packages not explicitly mapped below -->
      <package pattern="*" />
    </packageSource>
    <packageSource key="gitlab">
      <!-- Specify patterns for packages that should be restored from GitLab source -->
      <package pattern="Share.*" />
    </packageSource>
    <packageSource key="local">
      <!-- Specify patterns for packages that should be restored from GitLab source -->
      <package pattern="Share.*-dev" />
    </packageSource>
  </packageSourceMapping>
  
</configuration>